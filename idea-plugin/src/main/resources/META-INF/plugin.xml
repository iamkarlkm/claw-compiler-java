<idea-plugin>
    <id>com.claw.compiler.lsp</id>
    <name>Claw Compiler LSP</name>
    <version>1.0.0</version>
    <vendor>Claw Compiler Project</vendor>

    <description><![CDATA[
        <p>Language Server Protocol support for Claw compiler with code completion, syntax checking, and navigation features.</p>
        <ul>
            <li>Code completion with IntelliSense</li>
            <li>Real-time syntax checking</li>
            <li>Jump to definition</li>
            <li>Find references</li>
            <li>Hover information</li>
            <li>Auto-import suggestions</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Language Support -->
        <fileBasedProjectParser implementation="com.claw.lsp.idea.ClawLanguageParser"/>

        <!-- Syntax Highlighting -->
        <highlightUsagesHandlerFactory implementation="com.claw.lsp.idea.ClawHighlightUsagesHandlerFactory"/>

        <!-- Code Style -->
        <codeStyleSettingsProvider implementation="com.claw.lsp.idea.ClawCodeStyleSettingsProvider"/>
        <editorTabSizeProvider implementation="com.claw.lsp.idea.ClawEditorTabSizeProvider"/>

        <!-- Code Completion -->
        <completion.contributor language="Claw" implementationClass="com.claw.lsp.idea.ClawCompletionContributor"/>
        <completionSorterProvider implementation="com.claw.lsp.idea.ClawCompletionSorterProvider"/>

        <!-- LSP Integration -->
        <lsp.client.api.LspServerDefinitionProvider implementation="com.claw.lsp.idea.ClawLspServerDefinitionProvider"/>
        <lsp.client.api.LspServerEndpoint implementation="com.claw.lsp.idea.ClawLspServerEndpoint"/>
    </extensions>

    <actions>
        <!-- LSP Server Actions -->
        <group id="ClawLspActions" text="Claw LSP" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="Claw.ShowPerformanceReport"
                    class="com.claw.lsp.idea.action.ShowPerformanceReportAction"
                    text="Show Performance Report"
                    description="Show LSP performance report">

                <keyboard-shortcut keymap="$Default" first-keystroke="ctrl alt P"/>
            </action>

            <action id="Claw.ClearCache"
                    class="com.claw.lsp.idea.action.ClearCacheAction"
                    text="Clear Cache"
                    description="Clear LSP cache">

                <keyboard-shortcut keymap="$Default" first-keystroke="ctrl alt C"/>
            </action>

            <action id="Claw.RestartServer"
                    class="com.claw.lsp.idea.action.RestartServerAction"
                    text="Restart Server"
                    description="Restart LSP server">

                <keyboard-shortcut keymap="$Default" first-keystroke="ctrl alt R"/>
            </action>
        </group>
    </actions>

    <applicationListeners>
        <listener class="com.claw.lsp.idea.listener.ClawStartupListener"
                  topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>
</idea-plugin>
