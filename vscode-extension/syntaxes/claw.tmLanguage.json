{
    "$schema": "https://raw.githubusercontent.com/microsoft/vscode/master/schemas/vscode-color-theme.json",
    "name": "Claw Language",
    "scopeName": "source.claw",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#types"
        },
        {
            "include": "#annotations"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.claw",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.multiline.claw",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [
                        {
                            "include": "#comments"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.claw",
                    "match": "\\b(if|else|while|for|function|aspect|return|break|continue|switch|case|default|import|export|from|as|async|await|try|catch|throw|finally|typeof|instanceof|in|of|new|this|super|class|extends|implements)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.claw",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.claw",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.claw",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.claw",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.decimal.claw",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.float.claw",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.hex.claw",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.claw",
                    "match": "\\b0[bB][01]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.claw",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.claw",
                    "match": "\\b(Int|Float|String|Bool|Void|Any|number|string|boolean|void|any)\\b"
                }
            ]
        },
        "annotations": {
            "patterns": [
                {
                    "name": "storage.type.annotation.claw",
                    "match": "@\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.claw",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
                }
            ]
        }
    }
}
